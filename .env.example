## Example environment overrides for Arcanus Home
# Copy this to .env or set ARCANUS_HOME_ENV_FILE to point to a custom file.

# Where the mounted vault is available (recommended: /media/arcanus/ArcanusVault)
ARCANUS_VAULT_ROOT=/media/arcanus/ArcanusVault

# Where the Arcanus Practice frontend and backend projects live
ARCANUS_PRACTICE_ROOT=/media/arcanus/Arcanus Practice
ARCANUS_PRACTICE_FRONTEND=http://127.0.0.1:3002
ARCANUS_PRACTICE_BACKEND=http://127.0.0.1:3003

# Where the Arcanus Customs project lives
ARCANUS_CUSTOMS_ROOT=/media/arcanus/Arcanus Customs
ARCANUS_CUSTOMS_FRONTEND=http://127.0.0.1:3004

# Optional: path to the Arcanus Ledger binary inside the vault
ARCANUS_LEDGER_BINARY=/media/arcanus/ArcanusVault/Arcanus Ledger/arcanus_ledger

# Server host/port
ARCANUS_HOME_HOST=127.0.0.1
ARCANUS_HOME_PORT=8787
